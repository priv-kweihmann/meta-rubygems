From 4b98a3756b3f44af37df24acc3fb99d0871012e7 Mon Sep 17 00:00:00 2001
From: Konrad Weihmann <kweihmann@outlook.com>
Date: Tue, 17 Mar 2026 14:06:25 +0000
Subject: [PATCH] code: fix discarded-qualifiers errors

Upstream-Status: Pending
Signed-off-by: Konrad Weihmann <kweihmann@outlook.com>
---
 src/lib/krb5/ccache/ccbase.c                 | 3 ++-
 src/lib/krb5/os/expand_path.c                | 3 ++-
 src/lib/krb5/os/locate_kdc.c                 | 2 +-
 src/plugins/preauth/pkinit/pkinit_identity.c | 4 ++--
 src/plugins/preauth/pkinit/pkinit_matching.c | 2 +-
 5 files changed, 8 insertions(+), 6 deletions(-)

diff --git a/lib/krb5/ccache/ccbase.c b/lib/krb5/ccache/ccbase.c
index 696b681..ff8fcaa 100644
--- a/lib/krb5/ccache/ccbase.c
+++ b/lib/krb5/ccache/ccbase.c
@@ -201,7 +201,8 @@ krb5_cc_register(krb5_context context, const krb5_cc_ops *ops,
 krb5_error_code KRB5_CALLCONV
 krb5_cc_resolve (krb5_context context, const char *name, krb5_ccache *cache)
 {
-    char *pfx, *cp;
+    char *pfx;
+    const char *cp;
     const char *resid;
     unsigned int pfxlen;
     krb5_error_code err;
diff --git a/lib/krb5/os/expand_path.c b/lib/krb5/os/expand_path.c
index 5cbccf0..6569b88 100644
--- a/lib/krb5/os/expand_path.c
+++ b/lib/krb5/os/expand_path.c
@@ -454,7 +454,8 @@ k5_expand_path_tokens_extra(krb5_context context, const char *path_in,
 {
     krb5_error_code ret;
     struct k5buf buf;
-    char *tok_begin, *tok_end, *tok_val, **extra_tokens = NULL, *path;
+    const char *tok_begin, *tok_end;
+    char *tok_val, **extra_tokens = NULL, *path;
     const char *path_left;
     size_t nargs = 0, i;
     va_list ap;
diff --git a/lib/krb5/os/locate_kdc.c b/lib/krb5/os/locate_kdc.c
index d1df04a..967f228 100644
--- a/lib/krb5/os/locate_kdc.c
+++ b/lib/krb5/os/locate_kdc.c
@@ -223,7 +223,7 @@ parse_uri_if_https(const char *host_or_uri, k5_transport *transport,
         *transport = HTTPS;
         *host = host_or_uri + 8;
 
-        cp = strchr(*host, '/');
+        cp = strchr((char*)*host, '/');
         if (cp != NULL) {
             *cp = '\0';
             *uri_path = cp + 1;
diff --git a/plugins/preauth/pkinit/pkinit_identity.c b/plugins/preauth/pkinit/pkinit_identity.c
index 0dcfcfc..ded34da 100644
--- a/plugins/preauth/pkinit/pkinit_identity.c
+++ b/plugins/preauth/pkinit/pkinit_identity.c
@@ -473,7 +473,7 @@ process_option_ca_crl(krb5_context context,
                       const char *value,
                       int catype)
 {
-    char *residual;
+    const char *residual;
     unsigned int typelen;
     int idtype;
 
@@ -497,7 +497,7 @@ process_option_ca_crl(krb5_context context,
                                     plg_cryptoctx,
                                     req_cryptoctx,
                                     idopts, id_cryptoctx,
-                                    idtype, catype, residual);
+                                    idtype, catype, (char*)residual);
 }
 
 /*
diff --git a/plugins/preauth/pkinit/pkinit_matching.c b/plugins/preauth/pkinit/pkinit_matching.c
index 0ea072c..b3c8df1 100644
--- a/plugins/preauth/pkinit/pkinit_matching.c
+++ b/plugins/preauth/pkinit/pkinit_matching.c
@@ -262,7 +262,7 @@ parse_rule_component(krb5_context context,
     char err_buf[128];
     int ret;
     struct keyword_desc *kw, *nextkw;
-    char *nk;
+    const char *nk;
     int found_next_kw = 0;
     char *value = NULL;
     size_t len;
-- 
2.34.1

